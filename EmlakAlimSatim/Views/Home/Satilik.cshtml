@model List<EmlakAlimSatim.Models.Property>

@{
    ViewData["Title"] = "Satılık İlanlar";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}

<div class="container mt-5">

    ```
    <div class="section-title text-center mb-5">
        <h2>Satılık İlanlar</h2>
        <p>En yeni satılık gayrimenkul ilanları</p>
    </div>

    <div class="row">

        @foreach (var ilan in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card property-card shadow-sm border-0">

                    <div class="position-relative">
                        <img src="@ilan.CoverImage"
                             class="card-img-top"
                             style="height:220px; object-fit:cover;">

                        <span class="badge bg-danger position-absolute top-0 start-0 m-3">Satılık</span>

                        <span class="badge bg-dark position-absolute bottom-0 end-0 m-3">@ilan.Price.ToString("N0") ₺</span>
                    </div>

                    <div class="card-body">

                        <h5 class="card-title fw-bold">
                            @ilan.Title
                        </h5>

                        <p class="text-muted mb-2">
                            📍 @ilan.City?.Name / @ilan.District?.Name
                        </p>

                        <div class="d-flex justify-content-between small text-muted mb-3">
                            <span>🏠 @ilan.RoomCount Oda</span>
                            <span>📐 @ilan.SquareMeters m²</span>
                        </div>

                        <a href="/Property/Details/@ilan.Id"
                           class="btn btn-primary w-100">
                            İlan Detayı
                        </a>

                    </div>
                </div>
            </div>
        }

    </div>
    

</div>
