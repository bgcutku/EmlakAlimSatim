@model List<EmlakAlimSatim.Models.Property>
@{
    ViewData["Title"] = "Search";
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
}

<h2>Arama Sonuçları</h2>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-3">

            <div class="card">

                <img src="@item.CoverImage" class="card-img-top" />

                <div class="card-body">

                    <h5>@item.Title</h5>

                    <p>
                        @item.City.Name / @item.District.Name
                    </p>

                    <p>
                        @item.Price ₺
                    </p>

                    <a asp-controller="Property" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary">Detay</a>

                </div>

            </div>

        </div>
    }

</div>

