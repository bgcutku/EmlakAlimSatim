@model List<EmlakAlimSatim.Models.Kullanicilar>

@{
    ViewData["Title"] = "Kullanıcı Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Kullanıcı Listesi</h4>
            <a asp-area="Admin" asp-controller="Kullanici" asp-action="Create" class="btn btn-success btn-sm">+ Yeni Kullanıcı</a>
        </div>

        <div class="card-body table-responsive">

            <table class="table table-bordered table-hover align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Ad</th>
                        <th>Soyad</th>
                        <th>Email</th>
                        <th>Telefon</th>
                        <th>Rol</th>
                        <th>Kayıt Tarihi</th>
                        <th width="150">İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var kullanici in Model)
                    {
                        <tr>
                            <td>@kullanici.KullaniciID</td>
                            <td>@kullanici.Ad</td>
                            <td>@kullanici.Soyad</td>
                            <td>@kullanici.Email</td>
                            <td>@kullanici.PhoneNumber</td>

                            <td>
                                @if (kullanici.Role == "Admin")
                                {
                                    <span class="badge bg-danger">Admin</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-info text-dark">User</span>
                                }
                            </td>

                            <td>
                                @kullanici.KayitTarihi.ToString("dd.MM.yyyy")
                            </td>

                            <td><a asp-area="Admin" asp-controller="Kullanici" asp-action="Edit" asp-route-id="@kullanici.KullaniciID"
                                   class="btn btn-warning btn-sm">Düzenle</a>
                            
                                <a asp-area="Admin" asp-controller="Kullanici" asp-action="Delete" asp-route-id="@kullanici.KullaniciID"
                                   class="btn btn-danger btn-sm" onclick="return confirm('Silmek istediğinize emin misiniz?');">Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>