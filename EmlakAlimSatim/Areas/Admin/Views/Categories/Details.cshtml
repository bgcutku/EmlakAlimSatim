@model EmlakAlimSatim.Models.Category

@{
    ViewData["Title"] = "Kategori Detayları";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i> Kategori Bilgileri</h5>
                    <span class="badge bg-light text-dark">ID: #@Model.Id</span>
                </div>

                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <tbody>
                            <tr>
                                <th style="width: 30%" class="ps-4 bg-light text-secondary text-uppercase small">@Html.DisplayNameFor(model => model.Name)</th>
                                <td class="ps-4 fw-bold text-primary">@Html.DisplayFor(model => model.Name)</td>
                            </tr>
                            <tr>
                                <th class="ps-4 bg-light text-secondary text-uppercase small">@Html.DisplayNameFor(model => model.Icon)</th>
                                <td class="ps-4">
                                    <i class="@Model.Icon me-2 text-muted"></i>
                                    <code>@Html.DisplayFor(model => model.Icon)</code>
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-4 bg-light text-secondary text-uppercase small">@Html.DisplayNameFor(model => model.Description)</th>
                                <td class="ps-4 text-muted">
                                    @(Model.Description ?? "Bu kategori için bir açıklama girilmemiş.")
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-4 bg-light text-secondary text-uppercase small">@Html.DisplayNameFor(model => model.IsActive)</th>
                                <td class="ps-4">
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge rounded-pill bg-success px-3">
                                            <i class="fas fa-check-circle me-1"></i> Aktif
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger px-3">
                                            <i class="fas fa-times-circle me-1"></i> Pasif
                                        </span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="card-footer bg-white border-0 py-3 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 text-dark">
                        <i class="fas fa-edit"></i> Düzenle
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i> Listeye Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>