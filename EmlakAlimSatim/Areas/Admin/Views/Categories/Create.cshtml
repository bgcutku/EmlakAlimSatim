@model EmlakAlimSatim.Models.Category

@{
    ViewData["Title"] = "Yeni Kategori Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="card-title mb-0"><i class="fas fa-list-ul me-2"></i> Yeni Kategori Oluştur</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Kategori Adı</label>
                            <input asp-for="Name" class="form-control" placeholder="Örn: Müstakil Ev, Arsa..." />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Icon" class="form-label fw-bold">FontAwesome İkonu</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">
                                    <i id="iconPreview" class="fas fa-tag"></i>
                                </span>
                                <input asp-for="Icon" id="iconInput" class="form-control" placeholder="Örn: fa-home, fa-building" />
                            </div>
                            <small class="text-muted mt-1 d-block">FontAwesome kodu yazın (Örn: fa-home)</small>
                            <span asp-validation-for="Icon" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" checked>
                                <label class="form-check-label fw-bold" asp-for="IsActive">Kategori Aktif mi?</label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between border-top pt-3">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fas fa-save"></i> Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            $("#iconInput").on("input", function() {
                var iconClass = $(this).val();
                if(iconClass.trim() === "") {
                    $("#iconPreview").attr("class", "fas fa-tag");
                } else {
                    // Kullanıcı sadece 'fa-home' yazarsa 'fas fa-home' olarak birleştirir
                    $("#iconPreview").attr("class", "fas " + iconClass);
                }
            });
        });
    </script>
}