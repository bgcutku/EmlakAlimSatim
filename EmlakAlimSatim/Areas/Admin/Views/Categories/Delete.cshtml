@model EmlakAlimSatim.Models.Category

@{
    ViewData["Title"] = "Kategoriyi Sil";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-5">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white text-center">
                    <h4 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Dikkat: Silme İşlemi</h4>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <h5 class="text-muted">Bu kategoriyi silmek istediğinizden emin misiniz?</h5>
                        <p class="small text-danger">Bu işlem geri alınamayabilir.</p>
                    </div>

                    <hr />

                    <dl class="row px-3">
                        <dt class="col-sm-4 text-secondary">
                            <i class="fas fa-tag me-2"></i> @Html.DisplayNameFor(model => model.Name)
                        </dt>
                        <dd class="col-sm-8 fw-bold">
                            @Html.DisplayFor(model => model.Name)
                        </dd>

                        <dt class="col-sm-4 text-secondary">
                            <i class="fas fa-icons me-2"></i> @Html.DisplayNameFor(model => model.Icon)
                        </dt>
                        <dd class="col-sm-8">
                            <code>@Html.DisplayFor(model => model.Icon)</code>
                        </dd>

                        <dt class="col-sm-4 text-secondary">
                            <i class="fas fa-align-left me-2"></i> @Html.DisplayNameFor(model => model.Description)
                        </dt>
                        <dd class="col-sm-8">
                            @(string.IsNullOrEmpty(Model.Description) ? "Açıklama yok" : Model.Description)
                        </dd>

                        <dt class="col-sm-4 text-secondary">
                            <i class="fas fa-toggle-on me-2"></i> Durum
                        </dt>
                        <dd class="col-sm-8">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pasif</span>
                            }
                        </dd>
                    </dl>

                    <hr />

                    <form asp-action="Delete" class="d-flex justify-content-between">
                        <input type="hidden" asp-for="Id" />

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-undo"></i> Vazgeç ve Dön
                        </a>

                        <button type="submit" class="btn btn-danger px-4">
                            <i class="fas fa-trash-alt"></i> Evet, Sil
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>