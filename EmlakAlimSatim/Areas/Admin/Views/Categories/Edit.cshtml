@model EmlakAlimSatim.Models.Category

@{
    ViewData["Title"] = "Kategori Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="card-title mb-0">Kategori Düzenle</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <div class="form-group col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-bold">Kategori Adı</label>
                                <input asp-for="Name" class="form-control" placeholder="Örn: Konut, İş Yeri" />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="form-group col-md-6 mb-3">
                                <label asp-for="Icon" class="form-label fw-bold">İkon (Class)</label>
                                <input asp-for="Icon" class="form-control" placeholder="fa-solid fa-home" />
                                <span asp-validation-for="Icon" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input class="form-check-input" type="checkbox" asp-for="IsActive" id="statusCheck">
                            <label class="form-check-label fw-bold" for="statusCheck">
                                @Html.DisplayNameFor(model => model.IsActive) (Aktif mi?)
                            </label>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-secondary btn-sm">
                                <i class="fas fa-arrow-left"></i> Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-success px-4">
                                <i class="fas fa-save"></i> Güncellemeleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}