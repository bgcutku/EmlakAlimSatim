@model EmlakAlimSatim.Models.District

@{
    ViewData["Title"] = "Yeni İlçe Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white">
                    <h5 class="card-title mb-0"><i class="fas fa-plus-circle me-2"></i> Yeni İlçe Kaydı</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-4">
                            <label asp-for="CityId" class="form-label fw-bold text-dark">
                                <i class="fas fa-city me-1 text-primary"></i> Bağlı Olduğu Şehir
                            </label>
                            <select asp-for="CityId" class="form-select border-primary" asp-items="ViewBag.CityId">
                                <option value="" selected disabled>--- Lütfen Şehir Seçiniz ---</option>
                            </select>
                            <span asp-validation-for="CityId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-dark">
                                <i class="fas fa-map-marker-alt me-1 text-danger"></i> İlçe Adı
                            </label>
                            <input asp-for="Name" class="form-control border-primary" placeholder="Örn: Beşiktaş, Çankaya" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <hr class="mt-4">

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-list"></i> Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-success px-5">
                                <i class="fas fa-save"></i> Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}