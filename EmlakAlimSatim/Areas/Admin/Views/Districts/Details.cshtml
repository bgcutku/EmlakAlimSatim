@model EmlakAlimSatim.Models.District

@{
    ViewData["Title"] = "İlçe Detayları";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-7 mx-auto">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 text-center"><i class="fas fa-search-location me-2"></i> İlçe Detay Bilgileri</h5>
                </div>

                <div class="card-body p-0">
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr>
                                <th class="bg-light w-25 ps-4 py-3 text-secondary small text-uppercase">İlçe Adı</th>
                                <td class="ps-4 py-3 fw-bold text-dark">@Html.DisplayFor(model => model.Name)</td>
                            </tr>
                            <tr>
                                <th class="bg-light w-25 ps-4 py-3 text-secondary small text-uppercase">Bağlı Olduğu Şehir</th>
                                <td class="ps-4 py-3">
                                    <span class="badge bg-primary px-3 py-2 rounded-pill">
                                        <i class="fas fa-city me-1"></i> @Html.DisplayFor(model => model.City.Name)
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th class="bg-light w-25 ps-4 py-3 text-secondary small text-uppercase">Sistem Kayıt No</th>
                                <td class="ps-4 py-3 text-muted">#@Model.Id</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="card-footer bg-white border-0 py-4 d-flex justify-content-center gap-3">
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="fas fa-arrow-left"></i> Listeye Dön
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 shadow-sm">
                        <i class="fas fa-edit"></i> Bilgileri Güncelle
                    </a>
                </div>
            </div>

            <div class="text-center mt-3">
                <p class="small text-muted italic">Bu bilgiler emlak ilanlarında lokasyon belirlemek için kullanılmaktadır.</p>
            </div>
        </div>
    </div>
</div>