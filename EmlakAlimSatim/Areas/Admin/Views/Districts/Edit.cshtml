@model EmlakAlimSatim.Models.District

@{
    ViewData["Title"] = "İlçe Düzenle";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card shadow border-0">
                <div class="card-header bg-warning py-3">
                    <h5 class="card-title mb-0 text-dark">
                        <i class="fas fa-edit me-2"></i> İlçe Bilgilerini Güncelle
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-4">
                            <label asp-for="Name" class="form-label fw-bold">İlçe Adı</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-map-marker-alt text-warning"></i></span>
                                <input asp-for="Name" class="form-control" placeholder="İlçe adını giriniz" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="CityId" class="form-label fw-bold">Bağlı Olduğu Şehir</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fas fa-city text-warning"></i></span>
                                <select asp-for="CityId" class="form-select border-warning-subtle" asp-items="ViewBag.CityId"></select>
                            </div>
                            <span asp-validation-for="CityId" class="text-danger small"></span>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                                <i class="fas fa-arrow-left me-1"></i> Vazgeç
                            </a>
                            <button type="submit" class="btn btn-warning px-5 shadow-sm fw-bold">
                                <i class="fas fa-save me-1"></i> Değişiklikleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-3">
                <p class="text-muted small">
                    <i class="fas fa-info-circle me-1"></i> İlçe ismini değiştirmek, bu ilçeye bağlı mahalleleri de etkileyecektir.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}