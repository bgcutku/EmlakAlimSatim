@model EmlakAlimSatim.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Admin Giriş";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f5f6fa;
        }

        .login-container {
            max-width: 400px;
            margin: 80px auto;
            padding: 30px;
            background-color: #ffffff;
            border-radius: 10px;
            box-shadow: 0px 4px 12px rgba(0,0,0,0.1);
        }

            .login-container h2 {
                text-align: center;
                margin-bottom: 30px;
                color: #333333;
            }

        .btn-primary {
            width: 100%;
        }

        .error-message {
            color: #ff4d4f;
            text-align: center;
            margin-top: 15px;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <h2>Admin Giriş</h2>

        <form method="post">
            <div class="mb-3">
                <label asp-for="KullaniciAdi" class="form-label">Kullanıcı Adı</label>
                <input asp-for="KullaniciAdi" class="form-control" placeholder="Kullanıcı adınızı girin" />
            </div>

            <div class="mb-3">
                <label asp-for="Sifre" class="form-label">Şifre</label>
                <input asp-for="Sifre" type="password" class="form-control" placeholder="Şifrenizi girin" />
            </div>

            <button type="submit" class="btn btn-primary">Giriş Yap</button>

            @if (ViewBag.Hata != null)
            {
                <p class="error-message">@ViewBag.Hata</p>
            }
        </form>
    </div>
</body>
</html>